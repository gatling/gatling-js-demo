{
  "name": "gatling-ts-demo",
  "version": "3.14.905",
  "private": true,
  "type": "module",
  "main": "target/bundle",
  "dependencies": {
    "@gatling.io/core": "3.15.1",
    "@gatling.io/http": "3.15.1"
  },
  "devDependencies": {
    "@gatling.io/cli": "3.15.1",
    "prettier": "3.8.1",
    "rimraf": "6.1.3",
    "typescript": "6.0.2"
  },
  "scripts": {
    "clean": "rimraf target",
    "format": "prettier --write '**/*.ts'",
    "format-check": "prettier --check '**/*.ts'",
    "check": "tsc --noEmit",
    "build": "tsc --noEmit && gatling build --typescript",
    "recorder": "gatling recorder --typescript",
    "basicSimulation": "tsc --noEmit && gatling run --typescript --simulation basicSimulation"
  }
}
